digraph "example-foundation-order-cleanup" {
  graph [rankdir=LR, bgcolor="#fbfaf6", margin=0.2, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, color="#48758d", fillcolor="#d7ecf2"];
  edge [fontname="Comic Mono", fontsize=11, color="#47616f", fontcolor="#35505f", penwidth=2];
  step0 [label="PartnerRow\nraw tenant/order/items", fillcolor="#d7ecf2", color="#48758d"];
  step1 [label="Required fields\nrequire_not_blank", fillcolor="#edf1e9", color="#91a08c"];
  step2 [label="Optional defaults\nblank_to_default", fillcolor="#dbe8d4", color="#5d8a62"];
  step3 [label="Invalid items\nskip blank sku or qty <= 0", fillcolor="#f5d3df", color="#b95f7a"];
  step4 [label="CleanupReport\norders + skipped count", fillcolor="#f7e5aa", color="#b99b5d"];
  step5 [label="CapturedLogs\ncorrelation.id event", fillcolor="#eadcf5", color="#8a6bb0"];
  step0 -> step1 [label="", color="#47616f", fontcolor="#47616f"];
  step1 -> step2 [label="", color="#47616f", fontcolor="#47616f"];
  step2 -> step3 [label="", color="#47616f", fontcolor="#47616f"];
  step3 -> step4 [label="", color="#47616f", fontcolor="#47616f"];
  step4 -> step5 [label="", color="#47616f", fontcolor="#47616f"];
}
