digraph "workshop-foundation-sequence" {
  graph [rankdir=LR, bgcolor="#fbfaf6", margin=0.2, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, color="#48758d", fillcolor="#d7ecf2"];
  edge [fontname="Comic Mono", fontsize=11, color="#47616f", fontcolor="#35505f", penwidth=2];
  learner [label="Learner\nruns tests", fillcolor="#d7ecf2", color="#48758d"];
  cleanup [label="Cleanup Example\nnormalize rows", fillcolor="#dbe8d4", color="#5d8a62"];
  logging [label="Logging Example\ncapture event", fillcolor="#f7e5aa", color="#b99b5d"];
  scratch [label="Temp Resource\nwrite artifact", fillcolor="#eadcf5", color="#8a6bb0"];
  learner -> cleanup [label="1. normalize partner rows", color="#47616f", fontcolor="#47616f"];
  cleanup -> learner [label="validated order", color="#4f8b63", fontcolor="#4f8b63"];
  learner -> logging [label="2. assert correlation log", color="#a78335", fontcolor="#a78335"];
  logging -> learner [label="captured text", color="#4f8b63", fontcolor="#4f8b63"];
  learner -> scratch [label="3. write scratch rows", color="#47616f", fontcolor="#47616f"];
  scratch -> learner [label="cleanup verified", color="#4f8b63", fontcolor="#4f8b63"];
}
