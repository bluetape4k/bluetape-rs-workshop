digraph "workshop-foundation-architecture" {
  graph [rankdir=LR, bgcolor="#fbfaf6", margin=0.2, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, color="#48758d", fillcolor="#d7ecf2"];
  edge [fontname="Comic Mono", fontsize=11, color="#47616f", fontcolor="#35505f", penwidth=2];
  input [label="Partner Order Input\nraw rows + request context", fillcolor="#d7ecf2", color="#48758d"];
  cleanup [label="foundation-order-cleanup\nvalidate + normalize", fillcolor="#dbe8d4", color="#5d8a62"];
  tracing [label="request-tracing-log-capture\ncorrelation-aware logs", fillcolor="#f7e5aa", color="#b99b5d"];
  scratch [label="temp-resource-test-harness\ntemporary files", fillcolor="#eadcf5", color="#8a6bb0"];
  core [label="bluetape-rs-core\nvalidation helpers", fillcolor="#edf1e9", color="#91a08c"];
  logging [label="bluetape-rs-logging\ncapture subscriber", fillcolor="#edf1e9", color="#91a08c"];
  test [label="bluetape-rs-test\nTempDir harness", fillcolor="#edf1e9", color="#91a08c"];
  input -> cleanup [label="", color="#47616f", fontcolor="#47616f"];
  cleanup -> tracing [label="", color="#4f8b63", fontcolor="#4f8b63"];
  tracing -> scratch [label="", color="#a78335", fontcolor="#a78335"];
  core -> cleanup [label="", color="#47616f", fontcolor="#47616f"];
  logging -> tracing [label="", color="#a78335", fontcolor="#a78335"];
  test -> scratch [label="", color="#47616f", fontcolor="#47616f"];
}
